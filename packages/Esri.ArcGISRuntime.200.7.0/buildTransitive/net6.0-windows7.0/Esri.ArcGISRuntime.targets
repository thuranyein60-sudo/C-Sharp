<?xml version="1.0" encoding="utf-8"?>
<Project xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
   
  <Target Name="AGSRuntimeTFMCheck" BeforeTargets="ResolveAssemblyReferences;Build;Rebuild" Condition="'$(DisableAGSRuntimeTFMCheck)'!='true'">
    <Error Condition="'$(OutputType)'!='Library'"
        Text = "The 'Esri.ArcGISRuntime' nuget package cannot be used to target '$(TargetFramework)'. Target 'net8.0-windows10.0.19041.0' or later instead." />
  </Target>
  
</Project>
