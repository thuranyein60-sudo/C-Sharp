<?xml version="1.0" encoding="utf-8"?>
<Project xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
   
  <Target Name="AGSRuntimeTFMCheck" BeforeTargets="ResolveAssemblyReferences;Build;Rebuild" Condition="'$(AppxPackage)'!='true' AND '$(DisableAGSRuntimeTFMCheck)'!='true'">
    <Error 
        Text = "The 'Esri.ArcGISRuntime' nuget package cannot be used to target '$(TargetFramework)'. Target 'net8.0' or later instead." />
  </Target>
  
</Project>
